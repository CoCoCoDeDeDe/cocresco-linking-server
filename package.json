{
  "name": "tian-nong-iot-backend",
  "version": "1.1.0",
  "description": "基于Hono+MongoDB+Aedes自建MQTT自研物联网后端",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "hono",
    "mongodb",
    "iot",
    "aedes",
    "mqtt",
    "rules-engine"
  ],
  "author": "YourName",
  "license": "ISC",
  "dependencies": {
    "@hono/node-server": "^1.8.2",
    "@hono/zod-validator": "^0.2.0",
    "aedes": "^0.51.0",
    "aedes-persistence-mongodb": "^9.1.0",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "dotenv": "^16.4.5",
    "hono": "^4.0.8",
    "json-rules-engine": "^6.5.0",
    "mongodb": "^6.3.0",
    "mongoose": "^8.2.0",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/node": "^20.19.35",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
